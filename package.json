{
  "name": "media-clusterer",
  "version": "2.1.0",
  "description": "Local AI media clusterer with semantic search for photos and videos",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && wrangler pages deploy dist --project-name photo-organizer --assets=./dist"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@saehrimnir/druidjs": "^0.8.0"
  }
}
